# Credentials for the optional Stably AI-driven E2E suite.
#
# Copy this file to `.env` and fill in values from https://app.stably.ai to
# run `pnpm test:e2e:stably` locally. Leave empty if you only need the
# default `pnpm test:e2e` suite — the `electron-stably` Playwright project
# is only registered when STABLY_API_KEY is set.
STABLY_API_KEY=
STABLY_PROJECT_ID=
